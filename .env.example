# Պատճենեք այս ֆայլը `.env.local` (նույն պանակում, ինչ package.json-ը) և լրացրեք արժեքները։
# Next.js-ը ավտոմատ կկարդա .env.local-ը `npm run dev` / `npm run build` ժամանակ։

# MongoDB Atlas կամ տեղական Mongo connection string
MONGODB_URI=

# Տվյալների բազայի անուն (լռելյայն՝ hmt_form)
MONGODB_DB=hmt_form

# Collection-ի անուն (լռելյայն՝ submissions)
MONGODB_COLLECTION=submissions
