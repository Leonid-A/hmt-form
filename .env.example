# Պատճենեք այս ֆայլը `.env.local` (նույն պանակում, ինչ package.json-ը) և լրացրեք արժեքները։
# Next.js-ը ավտոմատ կկարդա .env.local-ը `npm run dev` / `npm run build` ժամանակ։

# MongoDB Atlas կամ տեղական Mongo connection string (միակ պարտադիր env)։
# Տվյալների բազան և collection-ը ֆիքսված են կոդում՝ config/server.ts → MONGODB_DB_NAME, MONGODB_COLLECTION_NAME
MONGODB_URI=

# --- Google Drive CSV prefill (ըստ ցանկության)։ Երկուսն էլ բացակայում են՝ prefill չի աշխատի։
# Սերվիս-հաշվի JSON key (ամբողջ ֆայլը մեկ տողով) կամ base64(JSON)
# GOOGLE_SERVICE_ACCOUNT_JSON=
# Drive ֆայլի ID (CSV կամ Google Sheet)
# DRIVE_PREFILL_FILE_ID=
# Եթե ֆայլը Google Sheets է՝ true
# DRIVE_FILE_IS_GOOGLE_SHEET=false
# CSV-ում header-ից հետո որ տողն է prefill-ի աղբյուրը (0 = առաջին տողը)
# DRIVE_PREFILL_DATA_ROW=0
